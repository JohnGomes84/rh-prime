NODE_ENV=development
PORT=3000

# Auth — JWT_SECRET must be 32+ chars (use: openssl rand -base64 48)
JWT_SECRET=

# Database (MySQL)
DATABASE_URL=mysql://user:pass@localhost:3306/rhprime

# OAuth (Manus)
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# CORS — comma separated origins
CORS_ORIGINS=http://localhost:3000

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# Storage (S3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
